# Telegram bot credentials for the backend lead notifications
BOT_TOKEN=your_telegram_bot_token
CHAT_ID=your_telegram_chat_id

# CORS origins allowed by the backend (comma-separated)
CORS_ORIGINS=http://localhost,https://rings-atelier.ru

# SWAG / Let's Encrypt settings
DOMAIN=rings-atelier.ru
SUBDOMAINS=
VALIDATION=http
EMAIL=your-email@example.com
ONLY_SUBDOMAINS=false
STAGING=false

# SWAG container user/group IDs (run `id` on the host to find yours)
PUID=1000
PGID=1000
TZ=Europe/Moscow
