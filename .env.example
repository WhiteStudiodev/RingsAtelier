# Telegram bot credentials for the backend lead notifications
BOT_TOKEN=your_telegram_bot_token
CHAT_ID=your_telegram_chat_id

# CORS origins allowed by the backend (comma-separated)
CORS_ORIGINS=http://localhost,https://rings-atelier.ru

# SMTP settings for backend email notifications (Yandex example)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your_yandex_login@yandex.ru
SMTP_PASSWORD=your_yandex_app_password
SMTP_FROM=your_yandex_login@yandex.ru
SMTP_TO=recipient@example.com

# SWAG / Let's Encrypt settings
DOMAIN=rings-atelier.ru
SUBDOMAINS=
VALIDATION=http
EMAIL=your-email@example.com
ONLY_SUBDOMAINS=false
STAGING=false

# SWAG container user/group IDs (run `id` on the host to find yours)
PUID=1000
PGID=1000
TZ=Europe/Moscow
